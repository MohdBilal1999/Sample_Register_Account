PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:5173

# MongoDB — use the connection string from Atlas (Connect → Drivers)
# Direct IP example:
# MONGODB_URI=mongodb://USERNAME:PASSWORD@134.238.248.245:27017/otp_registration?authSource=admin
# Atlas SRV example (replace cluster host from Atlas UI):
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/otp_registration?retryWrites=true&w=majority
# Atlas example:
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/otp_registration?retryWrites=true&w=majority

OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60
